{
  "name": "snug",
  "private": true,
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:contracts && turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "build:contracts": "bun run --cwd packages/contracts build",
    "dist:mac": "bun run build && node scripts/build-desktop-dmg.mjs",
    "dev:api": "bun run --cwd apps/api dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
