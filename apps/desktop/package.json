{
  "name": "@acme/desktop",
  "version": "0.1.1",
  "private": true,
  "description": "Snug — Electron shell for Remotion + agent workflows",
  "author": "Snug",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n BUNDLE,ELECTRON \"bun run dev:bundle\" \"bun run dev:electron\"",
    "dev:bundle": "tsup --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsup",
    "start": "electron dist-electron/main.js",
    "pack:mac": "node ../../scripts/build-desktop-dmg.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@acme/contracts": "workspace:*",
    "@acme/scaffold": "workspace:*",
    "electron-updater": "^6.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.snug.desktop",
    "productName": "Snug",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@acme/scaffold/**"
    ],
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "protocols": [
      {
        "name": "Snug",
        "schemes": [
          "snug"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://cdn.snug.video/releases/latest"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "${productName}",
      "artifactName": "${productName}.${ext}"
    }
  }
}
